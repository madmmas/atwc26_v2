# Raw ESPN payload cache for the qualifier/friendly history backfill (~700MB+).
# Not needed to run the app (data/historical_form.parquet is) or to resume an
# incremental re-run (data/history_games/*.parquet + historical_state.json
# already cover that) — only useful for re-deriving new fields without
# re-scraping, which matters far less for a mostly-static historical pull
# than for the live WC26 pipeline.
data/history_raw/

# frontend
frontend/out/

# v2 reference scripts (not part of v1 tree)
v2_scripts/

data/.gitkeep
data/.etl/

.pytest_cache

# k6 baseline JSON summaries (local only)
reports/

# Personal/company marketing content -- never goes in the repo
PUBLICITY_KIT.md

frontend/tsconfig.tsbuildinfo

