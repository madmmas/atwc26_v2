# Copy to terraform.tfvars and adjust before terraform apply.
# Candidate stack — separate name_prefix from production v1.

aws_region      = "us-east-1"
name_prefix     = "atwc26-v2"
environment     = "dev"
backend_api_url = "https://atwc26.com"

# Optional custom domain (certificate must be in us-east-1):
# aliases             = ["v2-dev.example.com"]
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."

enable_github_oidc = true
github_org         = "madmmas"
github_repo        = "atwc26_v2"

# Match-based ETL: EventBridge rate(5 minutes) → Lambda reads schedule.json
# and dispatches at kickoff+105m, then every 15m for 16 runs (4 hours).
# Fine-grained PAT needs Actions: Read and write on this repo.
# enable_etl_scheduler  = true
# github_dispatch_token = "github_pat_..."  # or export TF_VAR_github_dispatch_token
